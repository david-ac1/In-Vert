{
  "name": "invert-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "migrate": "tsx src/scripts/migrate.ts",
    "contract:compile": "tsx scripts/compile-contract.ts",
    "contract:deploy": "npm run contract:compile && tsx scripts/deploy-contract.ts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1010.0",
    "@hashgraph/sdk": "^2.68.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exifr": "^7.1.3",
    "express": "^5.1.0",
    "multer": "^2.1.1",
    "pg": "^8.16.3",
    "undici": "^7.24.4",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.37.0",
    "solc": "^0.8.34",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
